# =============================================================
# SP-RAG Environment Variables Example
# =============================================================

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Qdrant (Vector DB) ---
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=api-key-12345
QDRANT_COLLECTION=sp_rag_docs

# --- Redis (Exact + Semantic Cache) ---
REDIS_PORT=6380
REDIS_ADDR=localhost:6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL_SECONDS=3600
REDIS_SIMILARITY_THRESHOLD=0.85

# --- Kafka / Redpanda ---
KAFKA_PORT=9092
KAFKA_BROKER=localhost:9092
REDPANDA_CONSOLE_PORT=8080

# --- MinIO (Object Storage) ---
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=sprag
MINIO_ROOT_PASSWORD=sprag12345
MINIO_BUCKET=documents
MINIO_ENDPOINT=localhost:9000

# --- Gateway (Go API) ---
GATEWAY_PORT=8081
QUERY_TOP_K=5
QUERY_TIMEOUT_SECONDS=30

# --- SpiceDB (Authorization) ---
SPICEDB_GRPC_PORT=50051
SPICEDB_HTTP_PORT=8443
SPICEDB_ENDPOINT=localhost:50051
SPICEDB_PRESHARED_KEY=sprag_dev_key
SPICEDB_PG_PASSWORD=spicedb_secret